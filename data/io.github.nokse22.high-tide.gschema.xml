<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="tidal">
	<schema id="io.github.nokse22.high-tide" path="/io/github/nokse22/tidal/">
	  <key name="window-width" type="i">
      <default>1000</default>
    </key>
    <key name="window-height" type="i">
      <default>800</default>
    </key>
	  <key name="quality" type="i">
      <default>2</default>
    </key>
	  <key name="last-playing-index" type="i">
      <default>-1</default>
    </key>
	  <key name="last-playing-thing-id" type="s">
      <default>''</default>
    </key>
	  <key name="last-playing-thing-type" type="s">
      <default>''</default>
    </key>
	  <key name="last-volume" type="i">
      <default>10</default>
    </key>
	  <key name="repeat" type="i">
      <default>0</default>
    </key>
	  <key name="preferred-sink" type="i">
	    <range min="0" max="6"/>
      <default>0</default>
    </key>
	  <key name="run-background" type="b">
      <default>false</default>
    </key>
	  <key name="normalize" type="b">
      <default>false</default>
    </key>
	  <key name="quadratic-volume" type="b">
      <default>false</default>
    </key>
	  <key name="app-id-change-understood" type="b">
      <default>false</default>
    </key>
	  <key name="video-covers" type="b">
      <default>true</default>
    </key>
	  <key name="discord-rpc" type="b">
      <default>true</default>
    </key>
	  <key name="alsa-device" type="s">
      <default>'default'</default>
    </key>
	  <key name="auth-file-path" type="s">
      <default>''</default>
      <summary>Auth File Path</summary>
      <description>Path to the authentication file for storing client ID. Leave empty to use the default location (~/.high-tide/auth.json). Supports tilde expansion for home directory.</description>
    </key>
	  <key name="client-id" type="s">
      <default>''</default>
      <summary>Client ID</summary>
      <description>TIDAL API client ID. Leave empty to use the default device authentication flow, which will automatically populate this field after successful login.</description>
    </key>
	  <key name="lastfm-enabled" type="b">
      <default>false</default>
      <summary>Last.fm Scrobbling</summary>
      <description>Enable or disable Last.fm scrobbling of played tracks.</description>
    </key>
	  <key name="lastfm-scrobble-percentage" type="i">
      <range min="10" max="100"/>
      <default>50</default>
      <summary>Last.fm Scrobble Percentage</summary>
      <description>Percentage of a song that must be played before scrobbling to Last.fm. Valid range is 10-100.</description>
    </key>
	  <key name="lastfm-session-key" type="s">
      <default>''</default>
      <summary>Last.fm Session Key</summary>
      <description>Last.fm authentication session key. This is populated automatically after logging in with Last.fm.</description>
    </key>
	</schema>
</schemalist>
